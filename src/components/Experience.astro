---
import type { ExperienceItem } from '../data/cv';

interface Props {
  item: ExperienceItem;
}
const { item } = Astro.props;
---

<article class="exp">
  <h3 class="exp-role">{item.role}</h3>
  <p class="exp-company">{item.company}</p>
  <p class="exp-period">
    <time datetime={item.fromISO}>{item.from}</time> — <time datetime={item.toISO}>{item.to}</time>
  </p>
  <p class="exp-summary">{item.description}</p>
</article>
