---
import Section from './Section.astro';
import Experience from './Experience.astro';
import Skills from './Skills.astro';
import Contact from './Contact.astro';
import type { LocalizedCV, Contact as ContactType } from '../data/cv';

interface Props {
  cv: LocalizedCV;
  contact: ContactType;
  lang: string;
  printLabel: string;
}
const { cv, contact, lang, printLabel } = Astro.props;

const languages = [
  { code: 'en', label: 'EN', href: '/' },
  { code: 'ru', label: 'RU', href: '/ru/' },
  { code: 'ka', label: 'KA', href: '/ka/' },
];
---

<article class="cv">
  <header class="head">
    <div class="head-main">
      <h1 class="name">{cv.name}</h1>
      <p class="role">{cv.role}</p>
      <p class="headline-detail">{cv.headlineDetail}</p>
      <p class="loc">{cv.location} · {cv.availability}</p>
    </div>
    <div class="head-actions">
      <button
        class="action action-icon"
        type="button"
        onclick="window.print()"
        aria-label={printLabel}
        title={printLabel}
      >
        <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <path
            d="M13 2v7h7"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <text
            x="11.5"
            y="18.5"
            text-anchor="middle"
            fill="currentColor"
            stroke="none"
            font-size="7"
            font-weight="700"
            font-family="Inter, system-ui, sans-serif"
          >
            PDF
          </text>
        </svg>
      </button>
      <nav class="lang" aria-label="Language">
        {
          languages.map((l) =>
            l.code === lang ? (
              <span class="lang-current" aria-current="true">
                {l.label}
              </span>
            ) : (
              <a href={l.href} hreflang={l.code}>
                {l.label}
              </a>
            )
          )
        }
      </nav>
    </div>
  </header>

  <p class="summary">{cv.summary}</p>

  <Section label={cv.labels.skills}>
    <Skills groups={cv.skills} />
  </Section>

  <Section label={cv.labels.experience}>
    {cv.experience.map((e) => <Experience item={e} />)}
  </Section>

  <Section label={cv.labels.languages}>
    <div class="langs">
      {
        cv.languages.map((l) => (
          <div class="lang-row">
            <span class="lang-name">{l.name}</span>
            <span class="lang-level">{l.level}</span>
          </div>
        ))
      }
    </div>
  </Section>

  <Section label={cv.labels.education}>
    {
      cv.education.map((ed) => (
        <div class="edu">
          <span class="edu-school">{ed.school}</span>
          <span class="edu-meta">
            {ed.field} · {ed.year}
          </span>
        </div>
      ))
    }
  </Section>

  <Section label={cv.labels.openTo}>
    <p class="opento">{cv.openTo.join(' · ')}</p>
  </Section>

  <Section label={cv.labels.contact}>
    <Contact contact={contact} labels={cv.contactLabels} />
  </Section>
</article>
